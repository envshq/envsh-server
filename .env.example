# Database
DATABASE_URL=postgres://envsh:envsh@localhost:5432/envsh?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Server
SERVER_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json

# Email (console logs codes to stdout, suitable for dev)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@envsh.dev
# RESEND_API_KEY=re_xxxx   # required if EMAIL_PROVIDER=resend
